# Grok2API fork - contoh konfigurasi Docker Compose

# Port aplikasi
HOST_PORT=8000
SERVER_PORT=8000
SERVER_HOST=0.0.0.0
SERVER_WORKERS=1

# Logging dan zona waktu
LOG_LEVEL=INFO
TZ=Asia/Jakarta
FLARESOLVERR_LOG_LEVEL=info

# Storage
SERVER_STORAGE_TYPE=local
SERVER_STORAGE_URL=

# Cloudflare / FlareSolverr
FLARESOLVERR_URL=http://flaresolverr:8191
CF_REFRESH_INTERVAL=600
CF_TIMEOUT=60

# Catatan:
# - Untuk memakai proxy egress via service warp, jalankan compose dengan profile warp:
#     docker compose --profile warp up -d
# - Lalu arahkan konfigurasi aplikasi proxy.base_proxy_url ke:
#     socks5://warp:1080
# - File ini hanya template. Salin menjadi .env lalu sesuaikan nilainya.
